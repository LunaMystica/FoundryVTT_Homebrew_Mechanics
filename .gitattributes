# Normalize all text files to LF in the repo and on checkout (cross-platform).
* text=auto eol=lf

# Explicit text types (Foundry module sources).
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.hbs  text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf

# Binary assets — never normalized.
*.png  binary
*.jpg  binary
*.webp binary
*.ico  binary
*.woff2 binary
